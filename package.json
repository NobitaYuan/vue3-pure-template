{
  "name": "vue3-start-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build --mode development",
    "build-dev": "vite build --mode development",
    "build-test": "vite build --mode test",
    "build-pro": "vite build  --mode production",
    "preview": "vite preview",
    "cz": "cz",
    "prepare": "husky",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "generate:api": "openapi-typescript ../server-template/openapi.json -o src/api/generated/api.d.ts"
  },
  "dependencies": {
    "@vueuse/core": "^10.11.1",
    "animate.css": "^4.1.1",
    "axios": "^1.9.0",
    "commitizen": "^4.3.1",
    "nprogress": "^0.2.0",
    "openapi-fetch": "^0.17.0",
    "pinia": "^2.3.1",
    "pinia-plugin-persistedstate": "^4.7.1",
    "sass": "^1.89.2",
    "tdesign-icons-vue-next": "^0.4.1",
    "tdesign-vue-next": "^1.13.2",
    "version-polling": "^1.3.3",
    "vue": "^3.5.16",
    "vue-i18n": "^9.14.4",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "autoprefixer": "^10.4.21",
    "cz-git": "^1.11.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "postcss": "^8.5.5",
    "rollup-plugin-visualizer": "^7",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21",
    "unplugin-vue-components": "^29",
    "vite": "^8",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-vue-devtools": "^8.1.1"
  },
  "lint-staged": {
    "**/*": "oxfmt",
    "*.{js,ts,vue,jsx,tsx}": "oxlint --fix"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
